rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - User's unique ID
    //   - exp: number (required) - Total experience points
    //   - level: number (required) - Current level
    //   - streak: number (optional) - Current workout streak
    //   - lastWorkoutDate: string (optional) - ISO date
    //   - schedule: map (optional) - Weekly schedule
    //   - completedWorkouts: list (optional) - History
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'exp', 'level']) &&
             data.uid is string &&
             data.exp is number &&
             data.level is number &&
             data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId);
    }
  }
}
